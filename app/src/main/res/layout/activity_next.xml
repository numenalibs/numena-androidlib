<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="numenalibs.co.numenalibexample.UserSelectActivity">


    <EditText
        android:id="@+id/queryText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="ENTER QUERY" />

    <Button
        android:id="@+id/getUsersButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/queryText"
        android:text="Query Users" />

    <ListView
        android:id="@+id/numenaUserListView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentBottom="true"
        android:layout_below="@+id/getUsersButton"></ListView>

</RelativeLayout>
